<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>CascadeInstallerTest</AssemblyName>
    <RootNamespace>CascadeInstallerTest</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <IsAotCompatible>true</IsAotCompatible>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- The dogfood version. Bump this to publish a new release. -->
    <Version>1.0.0</Version>

    <PublishAot Condition="'$(Configuration)' == 'Release'">true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
    <StripSymbols>true</StripSymbols>
  </PropertyGroup>

  <!-- References the Cascade UI framework from the sibling repo. -->
  <ItemGroup>
    <ProjectReference Include="..\CascadeUI\src\Cascade.UI\Cascade.UI.csproj" />
    <ProjectReference Include="..\CascadeUI\src\Cascade.UI.Installer\Cascade.UI.Installer.csproj" />
  </ItemGroup>

  <Import Project="..\CascadeUI\src\Cascade.UI\build\Cascade.UI.targets" />

</Project>
